# New API 站点签到（HTTP + Cookie）

# 方式一：多站点 JSON 数组（推荐）
# userId 获取：F12 → Network → 刷新页面 → 点开 /api/user/self → 查看请求头 new-api-user
NEWAPI_ACCOUNTS=[{"name":"7r.fit","url":"https://api.7r.fit","session":"your_session_cookie","userId":123}]

# 方式二：单站点简写
# NEWAPI_URL=https://api.7r.fit
# NEWAPI_SESSION=your_session_cookie
# NEWAPI_USER_ID=123
# NEWAPI_NAME=7r.fit
