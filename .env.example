# New API 站点签到（HTTP + Cookie，推荐）

# 方式一：多站点 JSON 数组（推荐）
NEWAPI_ACCOUNTS=[{"name":"7r.fit","url":"https://api.7r.fit","session":"your_session_cookie"}]

# 方式二：单站点简写
# NEWAPI_URL=https://api.7r.fit
# NEWAPI_SESSION=your_session_cookie
# NEWAPI_NAME=7r.fit

# ViewTurbo 浏览器签到（启用 viewturbo-checkin 任务时使用）

# 方式一：单账号
# VIEWTURBO_EMAIL=your@email.com
# VIEWTURBO_PASSWORD=your_password

# 方式二：多账号 JSON 数组
# VIEWTURBO_ACCOUNTS=[{"email":"user1@example.com","password":"pass1"},{"email":"user2@example.com","password":"pass2"}]
